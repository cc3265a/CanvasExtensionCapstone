{
  "manifest_version": 2,
  "name": "CanvasExtensionCapstone",
  "version": "1.0",

  "description": "An extension for canvas",
  "host_permissions": [
    "https://*.instructure.com/*"
  ],
  
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content.js"]
    }
  ],
  "browser_action": {
    "browser_style": true,
    "default_icon": "icons/beasts-32.png",
    "default_title": "Tabulations",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ]

}