{
  "manifest_version": 2,
  "name": "CanvasExtensionCapstone",
  "version": "1.0",

  "description": "An extension for canvas",
  "host_permissions": [
    "https://*.instructure.com/*"
  ],
  
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content.js"]
    }
  ],
  "browser_action": {
    "browser_style": true,
    "default_icon": {
      "16": "TabIcon.png",
      "32": "TabIcon64.png"
    },
    "default_title": "Tabulations",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ],
  
  "icons": {
    "32": "TabIcon.png",
    "64": "TabIcon64.png"
  }

}